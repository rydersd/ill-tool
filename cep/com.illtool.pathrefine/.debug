<?xml version="1.0" encoding="UTF-8"?>
<!--
    Debug configuration for Path Detach & Refine panel.
    Enables Chrome DevTools access for debugging the panel's JavaScript.
    Access at: http://localhost:8092 when Illustrator is running with the panel loaded.
-->
<ExtensionList>
    <Extension Id="com.illtool.pathrefine.panel">
        <HostList>
            <Host Name="ILST" Port="8092" />
        </HostList>
    </Extension>
</ExtensionList>
