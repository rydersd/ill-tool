<?xml version="1.0" encoding="UTF-8"?>
<!--
    CEP 12 Manifest — Grouping Tools Panel for Illustrator.

    Path detachment, simplification, and grouping tools. Extracts selected
    anchor points into new paths, computes rotated bounding boxes, and applies
    Douglas-Peucker simplification. Evolving into full grouping/organization.

    Panel ID:    com.illtool.pathrefine
    Host:        Illustrator CC 2024+ (ILST 28.0+)
    Size:        280x480 (min 250x400)

    Installation:
        Run scripts/install-cep-panels.sh to symlink into the CEP extensions directory.
-->
<ExtensionManifest Version="7.0"
                   ExtensionBundleId="com.illtool.pathrefine"
                   ExtensionBundleVersion="1.0.0"
                   ExtensionBundleName="Grouping Tools"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.illtool.pathrefine.panel" Version="1.0.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <!-- Illustrator CC 2024+ (v28.0) through future versions -->
            <Host Name="ILST" Version="[28.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.illtool.pathrefine.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./jsx/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--allow-file-access-from-files</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                    <StartOn>
                        <Event>com.adobe.csxs.events.ApplicationActivate</Event>
                    </StartOn>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Grouping Tools</Menu>
                    <Geometry>
                        <Size>
                            <Height>480</Height>
                            <Width>280</Width>
                        </Size>
                        <MinSize>
                            <Height>400</Height>
                            <Width>250</Width>
                        </MinSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
