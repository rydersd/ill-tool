<?xml version="1.0" encoding="UTF-8"?>
<!--
    Debug configuration for Shape Averager panel.
    Enables Chrome DevTools access for debugging the panel's JavaScript.
    Access at: http://localhost:8091 when Illustrator is running with the panel loaded.
-->
<ExtensionList>
    <Extension Id="com.illtool.shapeaverager.panel">
        <HostList>
            <Host Name="ILST" Port="8091" />
        </HostList>
    </Extension>
</ExtensionList>
