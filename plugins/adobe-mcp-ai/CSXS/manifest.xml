<?xml version="1.0" encoding="UTF-8"?>
<!--
    CEP 12 Manifest — Adobe MCP Relay Panel for Illustrator.

    This panel connects to the MCP WebSocket relay server and executes
    JSX code received from MCP tools via CSInterface.evalScript().
    It replaces the osascript subprocess path with a persistent,
    bidirectional connection.

    Installation:
        Run scripts/install-cep-panels.sh to symlink into the CEP extensions directory.
-->
<ExtensionManifest Version="7.0"
                   ExtensionBundleId="com.adobemcp.ai"
                   ExtensionBundleVersion="1.0.0"
                   ExtensionBundleName="ill_tool Illustrator"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.adobemcp.ai.panel" Version="1.0.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <Host Name="ILST" Version="[25.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.adobemcp.ai.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <!-- ScriptPath omitted — polyfills loaded by relay-client.js at runtime -->
                    <CEFCommandLine>
                        <Parameter>--allow-file-access-from-files</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                    <StartOn>
                        <Event>com.adobe.csxs.events.ApplicationActivate</Event>
                    </StartOn>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>ill_tool</Menu>
                    <Geometry>
                        <Size>
                            <Height>200</Height>
                            <Width>250</Width>
                        </Size>
                        <MinSize>
                            <Height>150</Height>
                            <Width>200</Width>
                        </MinSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
